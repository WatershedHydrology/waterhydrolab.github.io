{%- comment -%}
  V2 footer — local override of al_folio_core's footer.liquid.
  Multi-column: brand + social, an "Explore" nav column, and a "Carriers"
  column of sharing / communication links, above the copyright bar.
  Email links are wrapped in Cloudflare email_off markers (split vars so the
  formatter can't rewrite them). Re-sync with the gem on upgrade.
{%- endcomment -%}
{%- assign eo_open = '<!--email' | append: '_off-->' -%}
{%- assign eo_close = '<!--/email' | append: '_off-->' -%}

<footer class="whl-foot2 {% if site.footer_fixed %}fixed-bottom{% else %}sticky-bottom mt-5{% endif %}" role="contentinfo">
  {% if site.newsletter.enabled and site.footer_fixed != true %}
    {% if site.plugins contains 'al_newsletter' %}
      {% include plugins/al_newsletter_form_center.liquid %}
    {% else %}
      {% include newsletter.liquid %}
    {% endif %}
  {% endif %}

  <div class="whl-foot2-grid">
    <div class="whl-foot2-brand">
      <img src="{{ '/assets/img/whl_logo_v2.png' | relative_url }}" alt="{{ site.title }} logo">
      <p>Advancing the science of water across agricultural landscapes, rangelands and watersheds. UF/IFAS RCREC · Ona, Florida.</p>
      <div class="whl-foot2-social">{% social_links %}</div>
    </div>

    <div class="whl-foot2-col">
      <h4>Explore</h4>
      {% for p in site.pages %}{% if p.permalink == '/' %}{% assign whl_home_title = p.title %}{% endif %}{% endfor %}
      <a href="{{ '/' | relative_url }}">{{ whl_home_title | default: 'Home' }}</a>
      {% assign whl_sorted = site.pages | sort: 'nav_order' %}
      {% for p in whl_sorted %}
        {% if p.nav and p.autogen == null and p.dropdown != true %}
          <a href="{{ p.url | relative_url }}">{{ p.title }}</a>
        {% endif %}
      {% endfor %}
    </div>

    <div class="whl-foot2-col">
      <h4>Carriers</h4>
      <a href="https://x.com/WaterHydroLab" target="_blank" rel="noopener"><i class="fa-brands fa-x-twitter"></i> @WaterHydroLab</a>
      <a href="https://github.com/waterhydrolab" target="_blank" rel="noopener"><i class="fa-brands fa-github"></i> waterhydrolab</a>
      {{ eo_open }}<a href="mailto:g.golmohammadi@ufl.edu"><i class="fa-solid fa-envelope"></i> Email the lab</a>{{ eo_close }}
      <a href="{{ '/downloads/' | relative_url }}"><i class="fa-solid fa-qrcode"></i> Downloads &amp; QR</a>
      <a href="{{ '/feed.xml' | relative_url }}"><i class="fa-solid fa-rss"></i> News feed (RSS)</a>
    </div>
  </div>

  <div class="whl-foot2-bottom">
    <small>
      &copy; {{ site.time | date: '%Y' }} {{ site.first_name }} {{ site.middle_name }} {{ site.last_name }}. {{ site.footer_text }}
      {% if site.last_updated %}Last updated {{ 'now' | date: '%B %d, %Y' }}.{% endif %}
    </small>
    <a href="{{ site.url }}">{{ site.url | remove: 'https://' | remove: 'http://' }}</a>
  </div>
</footer>
