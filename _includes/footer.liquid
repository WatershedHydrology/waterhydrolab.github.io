{%- comment -%}
  Local override of al_folio_core's footer.liquid.
  Adds a slim, delicate footer navigation bar (the same links as the main
  navbar, in the same gradient palette) on every page EXCEPT the homepage,
  above the copyright bar. The copyright bar itself is unchanged from upstream.
  Re-sync with the gem on upgrade.
{%- endcomment -%}
{% capture footer_contents %}
  &copy; Copyright {{ site.time | date: '%Y' }}
  {{ site.first_name }}
  {{ site.middle_name }}
  {{ site.last_name }}. {{ site.footer_text }}
  {% if site.impressum_path %}
    <a href="{{ site.url }}{{ site.baseurl }}{{ site.impressum_path }}">Impressum</a>.
  {% endif %}
  {% if site.last_updated %}
    Last updated: {{ 'now' | date: '%B %d, %Y' }}.
  {% endif %}
{% endcapture %}

{%- comment -%} WHL: slim footer navigation, shown on every page except home {%- endcomment -%}
{% capture whl_footer_nav %}
  {% if page.url != '/' %}
    {% for p in site.pages %}{% if p.permalink == '/' %}{% assign whl_home_title = p.title %}{% endif %}{% endfor %}
    <nav class="whl-foot-nav" aria-label="Footer navigation">
      <div class="whl-foot-nav-inner">
        <a class="whl-foot-link" href="{{ '/' | relative_url }}">{{ whl_home_title }}</a>
        {% assign whl_sorted = site.pages | sort: 'nav_order' %}
        {% for p in whl_sorted %}
          {% if p.nav and p.autogen == null and p.dropdown != true %}
            <a class="whl-foot-link {% if page.url == p.url %}active{% endif %}" href="{{ p.url | relative_url }}">{{ p.title }}</a>
          {% endif %}
        {% endfor %}
      </div>
    </nav>
  {% endif %}
{% endcapture %}

{% if site.footer_fixed %}
  {{ whl_footer_nav }}
  <footer class="fixed-bottom" role="contentinfo">
    <div class="container mt-0">
      {{ footer_contents }}
    </div>
  </footer>
{% else %}
  <footer class="sticky-bottom mt-5" role="contentinfo">
    {% if site.newsletter.enabled %}
      {% if site.plugins contains 'al_newsletter' %}
        {% include plugins/al_newsletter_form_center.liquid %}
      {% else %}
        {% include newsletter.liquid %}
      {% endif %}
    {% endif %}
    {{ whl_footer_nav }}
    <div class="container">
      {{ footer_contents }}
    </div>
  </footer>
{% endif %}
